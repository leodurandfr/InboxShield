# InboxShield — configuration d'environnement
# Copier vers `.env` puis adapter les valeurs.

# ─── Ports ───────────────────────────────────────────────
# Port sur lequel l'UI Nginx est exposée (reverse proxy vers backend:8000)
APP_PORT=8080

# ─── Base de données ─────────────────────────────────────
DB_PASSWORD=changeme_strong_password

# ─── Chiffrement des credentials IMAP (Fernet) ───────────
# Générer une clé avec :
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ─── Providers LLM ───────────────────────────────────────
# Ollama (LLM local). Dans Docker pur : http://ollama:11434
# Sur Mac avec Ollama natif : http://host.docker.internal:11434 (géré par docker-compose.mac.yml)
OLLAMA_BASE_URL=http://ollama:11434

# Clés API cloud (optionnelles — seulement si vous choisissez un provider cloud)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=

# ─── Debug ───────────────────────────────────────────────
DEBUG=false
